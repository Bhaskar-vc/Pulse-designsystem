<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=1512"/>
<title>Select Questions – Vantage Pulse</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@400;500;600&display=swap" rel="stylesheet"/>
<script src="https://mcp.figma.com/mcp/html-to-design/capture.js" async></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{min-height:100%;background:#f3f6fd;font-family:'Inter',sans-serif;font-size:14px;color:#29294c}
button{font-family:inherit;cursor:pointer;border:none;background:none}

/* ── NAVBAR ─────────────────────────────────────────────── */
.navbar{position:fixed;top:0;left:0;right:0;height:64px;background:transparent;border-bottom:none;display:flex;align-items:center;justify-content:space-between;padding:0 24px;z-index:200}
.navbar-left{display:flex;align-items:center;gap:12px}
.vc-logo-group{display:flex;align-items:center;gap:10px}
.vc-logo{display:flex;align-items:center}
.sidebar-toggle{display:flex;align-items:center;justify-content:center;padding:4px;border:none;background:none;cursor:pointer;border-radius:6px;flex-shrink:0}
.sidebar-toggle:hover{background:rgba(92,108,124,.12)}
.nav-divider{width:1px;height:28px;background:#e4e7ec;margin:0 4px}
.vp-brand{display:flex;align-items:center;gap:6px;font-size:14px;font-weight:500;color:#6941c6;padding:6px 16px 6px 10px;border-radius:50px}
.vp-brand svg{width:20px;height:20px;color:#6941c6}
.navbar-right{display:flex;align-items:center;gap:16px}
.nav-icons{display:flex;align-items:center;gap:16px}
.nav-icon-btn{width:24px;height:24px;display:flex;align-items:center;justify-content:center;color:#667085;cursor:pointer}
.nav-icon-btn svg{width:22px;height:22px}
.nav-avatar{width:32px;height:32px;border-radius:50%;overflow:hidden;cursor:pointer;background:#e9d7fe;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:600;color:#6941c6;flex-shrink:0}
.nav-avatar img{width:100%;height:100%;object-fit:cover;border-radius:50%}

/* ── SIDEBAR ─────────────────────────────────────────────── */
.side-nav{position:fixed;top:64px;left:0;width:252px;height:calc(100vh - 64px);background:transparent;border-right:none;display:flex;flex-direction:column;padding:16px 12px 24px;z-index:100;overflow-y:auto;transition:width .22s ease}
.sidebar-create-btn{display:flex;align-items:center;gap:8px;background:#7f56d9;color:#fff;font-size:14px;font-weight:500;padding:8px 16px 8px 12px;border-radius:8px;cursor:pointer;width:100%;margin-bottom:24px;transition:background .15s;border:none;overflow:hidden;white-space:nowrap}
.sidebar-create-btn:hover{background:#6941c6}
.sidebar-create-btn svg{width:20px;height:20px;flex-shrink:0}
.side-nav.collapsed{width:64px;padding:12px 8px;align-items:center}
.side-nav.collapsed .sidebar-create-btn{padding:8px;width:40px;min-width:unset;border-radius:10px;justify-content:center;margin-bottom:16px}
.side-nav.collapsed .sidebar-create-btn .btn-text{display:none}
.side-nav.collapsed .nav-item{justify-content:center;padding:10px 0;gap:0}
.side-nav.collapsed .nav-item-text,.side-nav.collapsed .nav-item-chevron,.side-nav.collapsed .nav-sub,.side-nav.collapsed .nav-pro-badge{display:none}
.side-nav.collapsed .nav-item-icon{width:20px;height:20px}
.side-nav.collapsed .nav-item-icon svg{width:20px;height:20px}
.sidebar-nav{display:flex;flex-direction:column;gap:2px;width:100%}
.nav-item{display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:8px;cursor:pointer;width:100%;transition:background .15s;font-size:12px;font-weight:500;color:#545470}
.nav-item:hover{background:#f9fafb}
.nav-item.active{color:#6941c6}
.nav-item-icon{width:16px;height:16px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.nav-item-icon svg{width:16px;height:16px}
.nav-item-text{flex:1;font-size:12px;font-weight:500}
.nav-item-chevron{width:16px;height:16px;display:flex;align-items:center;justify-content:center;color:#98a2b3;flex-shrink:0}
.nav-item-chevron svg{width:16px;height:16px}
.nav-item-chevron.open svg{transform:rotate(90deg)}
.nav-sub{display:flex;flex-direction:column;gap:0;position:relative;margin-left:13px}
.nav-sub::before{content:'';position:absolute;left:0;top:0;bottom:0;width:1px;background:#e4e7ec}
.nav-sub-item{display:flex;align-items:center;padding:8px 10px 8px 18px;font-size:12px;font-weight:500;color:#545470;cursor:pointer;border-radius:8px;transition:background .15s}
.nav-sub-item:hover{background:#f9fafb}
.nav-sub-item.active{color:#6941c6}
.nav-pro-badge{display:inline-flex;align-items:center;padding:2px 8px;border-radius:12px;font-size:12px;font-weight:400;color:#fff;background:linear-gradient(150deg,#dc6803 7%,#7f56d9 71%);line-height:16px}

/* ── PAGE SHELL ─────────────────────────────────────────────── */
.page{margin-top:64px;margin-left:252px;padding:0 16px 16px 0;height:calc(100vh - 64px);overflow:hidden;display:flex;flex-direction:column;transition:margin-left .22s ease}
.page-card{background:#fff;border-radius:16px;box-shadow:0 4px 16px rgba(16,24,40,.06);flex:1;display:flex;flex-direction:column;overflow:hidden;min-height:0}

/* ── TOP ROW: BACK + STEPPER ────────────────────────────────── */
.top-row{display:flex;align-items:center;padding:20px 30px 16px;gap:0;border-bottom:1px solid #f2f4f7;flex-shrink:0;min-height:72px}
.back-btn{display:flex;align-items:center;gap:6px;font-size:14px;font-weight:500;color:#29294c;padding:8px 10px;border-radius:8px;white-space:nowrap;transition:background .15s;flex-shrink:0}
.back-btn:hover{background:#f9fafb}
.back-btn svg{width:16px;height:16px;color:#545470}

.stepper{flex:1;display:flex;align-items:center;justify-content:center}
.step-item{display:flex;align-items:center;gap:8px}
.step-connector{width:54px;height:1px;background:#e4e7ec;margin:0 0}
.step-connector.done{background:#12b76a}
.step-circle{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.step-circle.done{background:#d1fadf}
.step-circle.done svg{width:14px;height:14px;color:#039855}
.step-circle.inactive{background:#f2f4f7}
.step-circle.inactive svg{width:14px;height:14px;color:#d0d5dd}
.step-label{font-size:14px;font-weight:400;line-height:1.4;white-space:nowrap}
.step-label.done-label{color:#29294c}
.step-label.inactive-label{color:#d0d5dd}

/* ── THREE PANELS ───────────────────────────────────────────── */
.panels{display:flex;flex:1;overflow:hidden;min-height:0}

/* ── LEFT: QUESTION BANK ────────────────────────────────────── */
.panel-bank{width:462px;flex-shrink:0;display:flex;flex-direction:column;border-right:1px solid #f2f4f7}
.pb-header{padding:14px 0 12px;flex-shrink:0}
.pb-title-row{display:flex;align-items:center;justify-content:space-between;padding:0 0 10px}
.pb-title{font-size:14px;font-weight:600;color:#29294c}
.pb-title span{font-weight:400;color:#98a2b3}
.pb-actions{display:flex;align-items:center;gap:0}

/* "Add all" checkbox style */
.add-all-wrap{display:flex;align-items:center;gap:6px;cursor:pointer;padding:2px 6px;border-radius:6px}
.add-all-wrap:hover{background:#f9fafb}
.add-all-cb{width:16px;height:16px;border:1.5px solid #d0d5dd;border-radius:4px;display:flex;align-items:center;justify-content:center;background:#fff;flex-shrink:0}
.add-all-cb.checked{background:#6941c6;border-color:#6941c6}
.add-all-cb svg{width:10px;height:10px;color:#fff}
.add-all-label{font-size:13px;color:#344054;font-weight:400}

.clear-btn{display:flex;align-items:center;gap:4px;font-size:13px;color:#344054;padding:2px 8px;border-radius:6px;transition:background .15s}
.clear-btn:hover{background:#fef3f2;color:#f04438}
.clear-btn svg{width:12px;height:12px}
.pb-divider-v{width:1px;height:16px;background:#e4e7ec;margin:0 4px}

.pb-search{padding:0 0 12px;flex-shrink:0;position:relative}
.pb-search input{width:100%;height:36px;padding:0 12px 0 34px;border:1px solid #d0d5dd;border-radius:6px;font-family:'Inter',sans-serif;font-size:13px;color:#344054;outline:none;transition:border-color .15s}
.pb-search input:focus{border-color:#7c3aed;box-shadow:0 0 0 3px rgba(124,58,237,.1)}
.pb-search input::placeholder{color:#98a2b3}
.pb-search-icon{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:#98a2b3;pointer-events:none}
.pb-search-icon svg{width:14px;height:14px}

.pb-body{flex:1;overflow-y:auto;padding:0}
.pb-body::-webkit-scrollbar{width:4px}
.pb-body::-webkit-scrollbar-thumb{background:#e4e7ec;border-radius:4px}

/* accordion */
.accord-header{display:flex;align-items:center;gap:0;padding:12px 0;cursor:pointer;user-select:none}
.accord-header:hover{background:#fafafa}
.accord-chevron{width:24px;height:24px;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:transform .2s}
.accord-chevron.closed{transform:rotate(-90deg)}
.accord-chevron svg{width:16px;height:16px;color:#545470}
.accord-title{font-size:14px;font-weight:500;color:#29294c;flex:1}
.accord-count{font-size:13px;color:#98a2b3}
.accord-body{overflow:hidden}
.accord-body.closed{display:none}

/* question card in bank */
.qcard{display:flex;align-items:center;gap:6px;padding:12px;border:1px solid #e1e5ea;border-radius:8px;margin-bottom:8px;background:#fff;transition:border-color .15s,box-shadow .15s}
.qcard:last-child{margin-bottom:12px}
.qcard:hover{border-color:#c9b8f5;box-shadow:0 1px 4px rgba(105,65,198,.08)}
.qcard.selected{border-color:#e1e5ea;background:#fff}
.qcard-content{flex:1;display:flex;flex-direction:column;gap:10px;min-width:0}
.qcard-text{font-size:14px;font-weight:500;color:#545470;line-height:20px}
.qcard-tag{display:inline-flex;align-items:center;padding:2px 8px;border-radius:16px;font-size:12px;font-weight:500;line-height:1.4;letter-spacing:.03px;white-space:nowrap}
.tag-rating{background:#f6fef9;border:.5px solid #039855;color:#039855}
.tag-mcq{background:#fffaeb;border:.5px solid #f79009;color:#b54708}
.tag-text-type{background:#eff8ff;border:.5px solid #2e90fa;color:#1849a9}
.tag-scale{background:#f9f5ff;border:.5px solid #9e77ed;color:#6941c6}
.tag-yesno{background:#f0fdf4;border:.5px solid #16a34a;color:#16a34a}
.tag-category{background:#fff;border:1px solid #d0d5dd;color:#29294c}

.add-q-btn{width:30px;height:30px;border-radius:8px;background:#7f56d9;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:background .15s,transform .1s}
.add-q-btn:hover{background:#6941c6;transform:scale(1.05)}
.add-q-btn.added{background:#fff;border:1.5px solid #fda29b}
.add-q-btn.added:hover{background:#fef3f2}
.add-q-btn svg{width:16px;height:16px;color:#fff}
.add-q-btn.added svg{color:#f04438}

/* ── CENTER: SELECTED QUESTIONS ──────────────────────────────── */
.panel-sel{flex:1;display:flex;flex-direction:column;border-right:1px solid #f2f4f7;min-width:0}
.ps-header{display:flex;align-items:flex-start;justify-content:space-between;padding:14px 24px 0;flex-shrink:0;gap:12px}
.ps-title-wrap{display:flex;flex-direction:column;gap:8px}
.ps-title{font-size:14px;font-weight:600;color:#29294c}
.ps-stats{font-size:12px;color:#707087;font-weight:400;line-height:1.4;letter-spacing:.03px;white-space:nowrap}
.ps-stats b{font-weight:400}
.add-custom-btn{display:flex;align-items:center;gap:4px;padding:4px 10px;border-radius:6px;border:1px solid #d0d5dd;background:#fff;font-size:12px;font-weight:500;color:#344054;white-space:nowrap;flex-shrink:0;transition:background .15s,border-color .15s}
.add-custom-btn:hover{background:#f9fafb;border-color:#98a2b3}
.add-custom-btn svg{width:12px;height:12px}
.ps-divider{height:1px;background:#f2f4f7;margin:12px 24px 0}

.ps-body{flex:1;overflow-y:auto;padding:12px 24px}
.ps-body::-webkit-scrollbar{width:4px}
.ps-body::-webkit-scrollbar-thumb{background:#e4e7ec;border-radius:4px}

/* selected question card */
.selq-card{border:1px solid #e1e5ea;border-radius:6px;background:#fff;padding:20px 24px;margin-bottom:8px}
.selq-inner{display:flex;align-items:center;gap:12px}
.selq-content{flex:1;display:flex;flex-direction:column;gap:10px;min-width:0}
.selq-text{font-size:14px;font-weight:500;color:#29294c;line-height:20px}
.selq-text .qnum{color:#707087}
.selq-tags{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.selq-chevron{width:24px;height:24px;display:flex;align-items:center;justify-content:center;flex-shrink:0;color:#98a2b3}
.selq-chevron svg{width:16px;height:16px}

/* empty state */
.sel-empty{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;color:#98a2b3;text-align:center;padding:40px 20px}
.sel-empty svg{width:88px;height:88px;opacity:.55}
.sel-empty-title{font-size:14px;font-weight:600;color:#667085}
.sel-empty-sub{font-size:13px;color:#98a2b3}

/* ── RIGHT: LIVE PREVIEW ─────────────────────────────────────── */
.panel-prev{width:400px;flex-shrink:0;display:flex;flex-direction:column;padding:20px;background:#f3f6fd}
.pp-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-shrink:0}
.pp-title{display:flex;align-items:center;gap:8px;font-size:14px;font-weight:500;color:#29294c}
.pp-title img,.pp-title svg{width:20px;height:20px}
.pp-collapse{width:24px;height:24px;display:flex;align-items:center;justify-content:center;border-radius:6px;color:#667085;transition:background .15s;cursor:pointer}
.pp-collapse:hover{background:rgba(0,0,0,.06)}
.pp-collapse svg{width:20px;height:20px}
.panel-prev{transition:width .25s ease,padding .25s ease}
.panel-prev.collapsed{width:52px;padding:16px 14px;overflow:hidden}
.panel-prev.collapsed .pp-title{display:none}
.panel-prev.collapsed .pp-body{display:none}
.panel-prev.collapsed .pp-header{justify-content:center}
.panel-prev.collapsed .pp-collapse img{transform:scaleX(-1)}

.pp-body{flex:1;display:flex;flex-direction:column;gap:0;overflow:hidden;min-height:0}
.pp-progress-row{display:flex;align-items:center;justify-content:center;gap:12px;margin-bottom:20px;flex-shrink:0}
.pp-prog-label{font-size:12px;color:#707087;font-weight:400;line-height:1.4;letter-spacing:.03px;white-space:nowrap}
.pp-prog-track{width:130px;height:7px;background:#f5fbff;border-radius:78px;overflow:hidden;position:relative}
.pp-prog-fill{height:100%;background:#98a2b3;border-radius:78px;width:51%}

.pp-card{background:#fff;border-radius:10px;box-shadow:0 4px 8px 0 rgba(16,24,40,.1),0 2px 4px 0 rgba(16,24,40,.06);padding:20px;display:flex;flex-direction:column;gap:30px;flex:1;overflow-y:auto;min-height:0}
.pp-card::-webkit-scrollbar{width:3px}
.pp-card::-webkit-scrollbar-thumb{background:#e4e7ec;border-radius:4px}

.pp-question-text{font-size:14px;font-weight:600;color:#29294c;line-height:1.4;letter-spacing:.021px}
.pp-rating-wrap{display:flex;flex-direction:column;gap:10px}
.pp-rating-btns{display:flex;gap:12px}
.rating-btn{width:44px;height:48px;border:1px solid #d0d5dd;border-radius:8px;background:#fff;display:flex;align-items:center;justify-content:center;font-family:'Poppins',sans-serif;font-size:16px;font-weight:500;color:#545470;letter-spacing:.024px;cursor:pointer;transition:border-color .15s,background .15s,color .15s;flex-shrink:0}
.rating-btn:hover{border-color:#7f56d9;background:#f4f3ff;color:#6941c6}
.rating-btn.selected-r{background:#f4f3ff;border-color:#7f56d9;color:#6941c6}
.pp-rating-labels{display:flex;justify-content:space-between;font-size:12px;color:#707087;line-height:1.4;letter-spacing:.03px}

.pp-comment-wrap{display:flex;flex-direction:column;gap:4px}
.pp-comment-label{font-size:12px;color:#545470;font-weight:400;line-height:1.4;letter-spacing:.03px}
.pp-comment-input{width:100%;height:80px;border:1px solid #d0d5dd;border-radius:6px;padding:8px 16px;font-family:'Inter',sans-serif;font-size:14px;color:#101828;resize:none;outline:none;transition:border-color .15s}
.pp-comment-input:focus{border-color:#7f56d9;box-shadow:0 0 0 3px rgba(127,86,217,.1)}

.pp-skip-btn{display:inline-flex;align-items:center;gap:8px;padding:10px 0;font-size:12px;font-weight:500;color:#6941c6;line-height:1.4;letter-spacing:.03px;cursor:pointer;background:none;border:none}
.pp-skip-btn svg{width:16px;height:16px}

.pp-nav{display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.pp-nav-btn{display:flex;align-items:center;gap:4px;min-width:60px;width:88px;padding:4px 12px;border-radius:50px;border:1px solid #d0d5dd;background:#fff;font-family:'Poppins',sans-serif;font-size:12px;font-weight:500;color:#29294c;justify-content:center;transition:background .15s}
.pp-nav-btn:hover:not(:disabled){background:#f9fafb}
.pp-nav-btn:disabled,.pp-nav-btn.disabled{color:#d0d5dd;border-color:#d0d5dd;cursor:not-allowed}
.pp-nav-btn svg{width:16px;height:16px;flex-shrink:0}

.pp-empty{flex:1;display:flex;align-items:center;justify-content:center;font-size:13px;color:#98a2b3;text-align:center;padding:20px}

/* ── FOOTER ─────────────────────────────────────────────────── */
.page-footer{height:62px;border-top:1px solid #f2f4f7;display:flex;align-items:center;justify-content:space-between;padding:0 30px;flex-shrink:0}
.cancel-btn{height:36px;padding:0 20px;border-radius:6px;border:1px solid #d0d5dd;background:#fff;font-size:14px;font-weight:500;color:#344054;transition:background .15s}
.cancel-btn:hover{background:#f9fafb}
.continue-btn{display:flex;align-items:center;gap:6px;height:36px;padding:0 20px;border-radius:6px;background:#29294c;border:none;font-size:14px;font-weight:500;color:#fff;transition:background .15s,opacity .15s}
.continue-btn:hover:not(:disabled){background:#1d1d38}
.continue-btn:disabled{opacity:.4;cursor:not-allowed}
.continue-btn svg{width:16px;height:16px}

/* ── MODAL ───────────────────────────────────────────────────── */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.3);backdrop-filter:blur(2px);z-index:500;display:none;align-items:center;justify-content:center}
.modal-overlay.open{display:flex}
.modal-box{background:#fff;border-radius:16px;padding:28px;width:480px;box-shadow:0 20px 60px rgba(0,0,0,.15);animation:mIn .2s ease}
@keyframes mIn{from{transform:scale(.96);opacity:0}to{transform:scale(1);opacity:1}}
.modal-title{font-size:18px;font-weight:700;color:#1d2939;margin-bottom:4px}
.modal-sub{font-size:13px;color:#667085;margin-bottom:20px}
.form-group{margin-bottom:16px}
.form-label{display:block;font-size:13px;font-weight:500;color:#344054;margin-bottom:6px}
.form-control{width:100%;padding:9px 12px;border:1px solid #d0d5dd;border-radius:8px;font-size:14px;color:#1d2939;outline:none;font-family:'Inter',sans-serif;transition:border-color .15s}
.form-control:focus{border-color:#7c3aed;box-shadow:0 0 0 3px rgba(124,58,237,.1)}
textarea.form-control{resize:vertical;min-height:80px}
.modal-actions{display:flex;gap:10px;justify-content:flex-end;margin-top:24px}
.modal-cancel{padding:9px 18px;border-radius:8px;border:1px solid #d0d5dd;background:#fff;font-size:14px;font-weight:500;color:#344054;cursor:pointer}
.modal-submit{padding:9px 18px;border-radius:8px;border:none;background:#6941c6;color:#fff;font-size:14px;font-weight:500;cursor:pointer}
.modal-submit:hover{background:#5b21b6}

/* ── TOAST ───────────────────────────────────────────────────── */
.toast-container{position:fixed;bottom:24px;right:24px;z-index:600;display:flex;flex-direction:column;gap:8px;pointer-events:none}
.toast{background:#1d2939;color:#fff;padding:10px 16px;border-radius:10px;font-size:13px;font-weight:500;box-shadow:0 4px 16px rgba(0,0,0,.2);display:flex;align-items:center;gap:8px;animation:tIn .3s ease;opacity:1;transition:opacity .3s}
.toast.success{background:#039855}
@keyframes tIn{from{transform:translateY(10px);opacity:0}to{transform:translateY(0);opacity:1}}

/* ── BANK HEADER PADDING ─────────────────────────────────────── */
.pb-inner{padding:0 0 0 0}
.pb-header,.pb-title-row,.pb-search,.accord-header,.qcard{padding-left:0;padding-right:0}
.pb-title-row{padding:12px 0 10px}
</style>
</head>
<body>

<!-- NAVBAR -->
<nav class="navbar">
  <div class="navbar-left">
    <div class="vc-logo-group">
      <a href="create-survey.html" class="vc-logo">
        <img src="vc-logo.svg" height="22" alt="VantageCircle"/>
      </a>
