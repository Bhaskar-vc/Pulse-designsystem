<!-- MAIN PAGE -->
<div class="page">
  <div class="page-card">

    <!-- TOP ROW: BACK + STEPPER -->
    <div class="top-row">
      <button class="back-btn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Back
      </button>
      <div class="stepper">
        <!-- Step 1: Get Started (done) -->
        <div class="step-item">
          <div class="step-circle done">
            <svg viewBox="0 0 14 14" fill="none"><path d="M2.333 7l3 3 6-6" stroke="#039855" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <span class="step-label done-label">Get Started</span>
        </div>
        <div class="step-connector done"></div>
        <!-- Step 2: Select Questions (done) -->
        <div class="step-item">
          <div class="step-circle done">
            <svg viewBox="0 0 14 14" fill="none"><path d="M2.333 7l3 3 6-6" stroke="#039855" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <span class="step-label done-label">Select Questions</span>
        </div>
        <div class="step-connector"></div>
        <!-- Step 3: Configure (inactive) -->
        <div class="step-item">
          <div class="step-circle inactive">
            <svg viewBox="0 0 14 14" fill="none"><path d="M2.333 7l3 3 6-6" stroke="#d0d5dd" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <span class="step-label inactive-label">Configure</span>
        </div>
        <div class="step-connector"></div>
        <!-- Step 4: Preview & Launch (inactive) -->
        <div class="step-item">
          <div class="step-circle inactive">
            <svg viewBox="0 0 14 14" fill="none"><path d="M2.333 7l3 3 6-6" stroke="#d0d5dd" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <span class="step-label inactive-label">Preview &amp; Launch</span>
        </div>
      </div>
    </div>

    <!-- THREE PANELS -->
    <div class="panels">

      <!-- LEFT: QUESTION BANK -->
      <div class="panel-bank" style="padding:0 0 0 0">
        <div style="padding:0 16px;flex:1;display:flex;flex-direction:column;min-height:0">

          <!-- Bank header -->
          <div style="padding-top:12px;flex-shrink:0">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
              <div style="font-size:14px;font-weight:600;color:#29294c">
                Question Bank <span id="bank-count" style="font-weight:400;color:#98a2b3">(35)</span>
              </div>
              <div style="display:flex;align-items:center;gap:0">
                <!-- Add all checkbox -->
                <div style="display:flex;align-items:center;gap:6px;cursor:pointer;padding:3px 6px;border-radius:6px" onclick="addAllQuestions()" onmouseenter="this.style.background='#f9fafb'" onmouseleave="this.style.background='transparent'">
                  <div id="add-all-cb" style="width:16px;height:16px;border:1.5px solid #d0d5dd;border-radius:4px;display:flex;align-items:center;justify-content:center;background:#fff;flex-shrink:0">
                    <svg width="10" height="10" viewBox="0 0 12 12" fill="none" style="display:none" id="add-all-check"><path d="M1.5 6L4.5 9L10.5 3" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </div>
                  <span style="font-size:13px;color:#344054">Add all</span>
                </div>
                <div id="clear-all-divider" style="display:none;width:1px;height:16px;background:#e4e7ec;margin:0 6px"></div>
                <button id="clear-all-btn" onclick="clearAllQuestions()" style="display:none;align-items:center;gap:4px;font-size:13px;color:#344054;padding:3px 6px;border-radius:6px;background:transparent;border:none;cursor:pointer" onmouseenter="this.style.background='#fef3f2';this.style.color='#f04438'" onmouseleave="this.style.background='transparent';this.style.color='#344054'">
                  <svg width="11" height="11" viewBox="0 0 12 12" fill="none"><path d="M9 3L3 9M3 3l6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  Clear All
                </button>
              </div>
            </div>
            <!-- Search -->
            <div style="position:relative;margin-bottom:12px">
              <svg style="position:absolute;left:10px;top:50%;transform:translateY(-50%);color:#98a2b3;pointer-events:none;width:14px;height:14px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              <input id="search-input" type="text" placeholder="Search questions" oninput="filterQuestions(this.value)"
                style="width:100%;height:36px;padding:0 12px 0 32px;border:1px solid #d0d5dd;border-radius:6px;font-family:'Inter',sans-serif;font-size:13px;color:#344054;outline:none;transition:border-color .15s"
                onfocus="this.style.borderColor='#7c3aed';this.style.boxShadow='0 0 0 3px rgba(124,58,237,.1)'"
                onblur="this.style.borderColor='#d0d5dd';this.style.boxShadow='none'"/>
            </div>
          </div>

          <!-- Accordion list -->
          <div id="question-bank" style="flex:1;overflow-y:auto;padding-bottom:16px">
            <!-- rendered by JS -->
          </div>
        </div>
      </div>

      <!-- CENTER: SELECTED QUESTIONS -->
      <div class="panel-sel">
        <div class="ps-header">
          <div class="ps-title-wrap">
            <div class="ps-title">Selected Questions</div>
            <div class="ps-stats" id="ps-stats">
              <span id="stat-count">0</span> questions selected &nbsp;from <span id="stat-cats">0</span> categories • ~<span id="stat-time">0</span>s to complete
            </div>
          </div>
          <button class="add-custom-btn" onclick="openCustomModal()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Add Custom Question
          </button>
        </div>
        <div class="ps-divider"></div>
        <div class="ps-body" id="sel-body">
          <!-- rendered by JS -->
        </div>
      </div>

      <!-- RIGHT: LIVE PREVIEW -->
      <div class="panel-prev">
        <!-- Header -->
        <div class="pp-header">
          <div class="pp-title">
            <img src="https://www.figma.com/api/mcp/asset/ddebc936-6070-4f58-a782-49ae6e44b5e6" width="20" height="20" alt=""/>
            Live Preview
          </div>
          <button class="pp-collapse" title="Collapse" onclick="togglePreview()">
            <img src="https://www.figma.com/api/mcp/asset/39485630-f29c-47ba-94cb-bc78c3198610" width="24" height="24" alt=""/>
          </button>
        </div>

        <div class="pp-body" id="preview-body">
          <!-- rendered by JS -->
        </div>
      </div>
    </div>

    <!-- FOOTER -->
    <div class="page-footer">
      <button class="cancel-btn" onclick="if(confirm('Cancel survey creation?')) location.reload()">Cancel</button>
      <button class="continue-btn" id="continue-btn" disabled>
        Continue
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </button>
    </div>
  </div>
</div>

<!-- CUSTOM QUESTION MODAL -->
<div class="modal-overlay" id="custom-modal" onclick="if(event.target===this)closeCustomModal()">
  <div class="modal-box">
    <div class="modal-title">Add Custom Question</div>
    <div class="modal-sub">Create a question tailored to your survey needs.</div>
    <div class="form-group">
      <label class="form-label">Question Text *</label>
      <textarea class="form-control" id="cq-text" placeholder="Enter your question here..."></textarea>
    </div>
    <div class="form-group">
      <label class="form-label">Question Type</label>
      <select class="form-control" id="cq-type">
        <option value="Rating Scale (1-5)">Rating Scale (1-5)</option>
        <option value="MCQ">Multiple Choice (MCQ)</option>
        <option value="Yes/No">Yes / No</option>
        <option value="Text">Open Text</option>
        <option value="Scale (1-10)">Scale (1-10)</option>
      </select>
    </div>
    <div class="form-group">
      <label class="form-label">Category</label>
      <select class="form-control" id="cq-cat">
        <option value="">— Select Category —</option>
        <option>Recognition</option><option>Employee Satisfaction</option>
        <option>Compensation and Benefits</option><option>Wellness</option>
        <option>Manager Effectiveness</option><option>Work-Life Balance</option>
        <option>Diversity &amp; Inclusion</option><option>Custom</option>
      </select>
    </div>
    <div class="modal-actions">
      <button class="modal-cancel" onclick="closeCustomModal()">Cancel</button>
      <button class="modal-submit" onclick="submitCustom()">Add Question</button>
    </div>
  </div>
</div>

<div class="toast-container" id="toasts"></div>

<script>
// ── DATA ────────────────────────────────────────────────────────
const CATEGORIES = [
  { name:'Recognition', questions:[
    {id:1, text:'My organization encourages employees to give recognition to one another', type:'Rating Scale (1-5)'},
    {id:2, text:'If I do great work, I know that it will be recognised', type:'Rating Scale (1-5)'},
    {id:3, text:'Horem ipsum dolor sit amet, consectetur adipiscing elit. Nunc vulputate libero et velit interdum, ac aliquet odio mattis ...', type:'MCQ'},
  ]},
  { name:'Employee Satisfaction', questions:[
    {id:4, text:'Overall, how satisfied are you with working at this organization?', type:'Rating Scale (1-5)'},
    {id:5, text:'I feel proud to work for this organization.', type:'Rating Scale (1-5)'},
    {id:6, text:'I would recommend this organization as a great place to work.', type:'Scale (1-10)'},
    {id:7, text:'My work gives me a feeling of personal accomplishment.', type:'Rating Scale (1-5)'},
    {id:8, text:'What is one thing that would improve your work experience?', type:'Text'},
  ]},
  { name:'Compensation and Benefits', questions:[
    {id:9, text:'I believe my pay is fair for the work I do.', type:'Rating Scale (1-5)'},
    {id:10, text:'The benefits package offered by my organization meets my needs.', type:'Rating Scale (1-5)'},
    {id:11, text:'Which benefit matters most to you?', type:'MCQ'},
  ]},
  { name:'Wellness', questions:[
    {id:12, text:'My organization supports my physical and mental wellbeing.', type:'Rating Scale (1-5)'},
    {id:13, text:'I feel I have enough energy at the end of a typical workday.', type:'Yes/No'},
  ]},
  { name:'Manager Effectiveness', questions:[
    {id:14, text:'My manager provides me with regular, useful feedback.', type:'Rating Scale (1-5)'},
    {id:15, text:'My manager genuinely cares about my career development.', type:'Rating Scale (1-5)'},
    {id:16, text:'My manager creates an environment where I feel safe to speak up.', type:'Rating Scale (1-5)'},
    {id:17, text:'How effective is your manager at removing obstacles for your team?', type:'Scale (1-10)'},
    {id:18, text:'My manager clearly communicates team goals and expectations.', type:'Rating Scale (1-5)'},
  ]},
  { name:'Work-Life Balance', questions:[
    {id:19, text:'I am able to maintain a healthy balance between my work and personal life.', type:'Rating Scale (1-5)'},
    {id:20, text:'My workload is manageable on a day-to-day basis.', type:'Rating Scale (1-5)'},
    {id:21, text:'I am able to disconnect from work outside of working hours.', type:'Yes/No'},
    {id:22, text:'How often do you work beyond your contracted hours?', type:'MCQ'},
  ]},
  { name:'Diversity & Inclusion', questions:[
    {id:23, text:'People from all backgrounds are treated fairly in this organization.', type:'Rating Scale (1-5)'},
    {id:24, text:'I feel I can be myself at work without fear of judgment.', type:'Rating Scale (1-5)'},
    {id:25, text:'My organization takes diversity and inclusion seriously.', type:'Rating Scale (1-5)'},
    {id:26, text:'Have you witnessed or experienced discrimination at work in the past year?', type:'Yes/No'},
  ]},
  { name:'Learning & Development', questions:[
    {id:27, text:'I have access to the learning and development resources I need.', type:'Rating Scale (1-5)'},
    {id:28, text:'My organization invests in my professional growth.', type:'Rating Scale (1-5)'},
    {id:29, text:'I have had meaningful career conversations with my manager this year.', type:'Yes/No'},
    {id:30, text:'Which learning format do you prefer?', type:'MCQ'},
  ]},
  { name:'Team Collaboration', questions:[
    {id:31, text:'My team works well together to achieve common goals.', type:'Rating Scale (1-5)'},
    {id:32, text:'I trust my team members to do their part.', type:'Rating Scale (1-5)'},
    {id:33, text:'Communication within my team is clear and open.', type:'Rating Scale (1-5)'},
    {id:34, text:'My team celebrates wins and learns from setbacks together.', type:'Rating Scale (1-5)'},
    {id:35, text:'How would you rate cross-team collaboration in your organization?', type:'Scale (1-10)'},
  ]},
];

// State
let selectedIds   = new Set();
let collapsed     = new Set(['Employee Satisfaction','Compensation and Benefits','Wellness','Manager Effectiveness','Work-Life Balance','Diversity & Inclusion','Learning & Development','Team Collaboration']);
let searchQuery   = '';
let customCounter = 1000;
let previewRating = null;
let previewIndex  = 0;

function getAllQs() {
  const r = [];
  CATEGORIES.forEach(c => c.questions.forEach(q => r.push({...q, category:c.name})));
  return r;
}

function badgeClass(t) {
  if (t.startsWith('Rating')||t.startsWith('Scale')) return 'tag-rating';
  if (t==='MCQ') return 'tag-mcq';
  if (t==='Text') return 'tag-text-type';
  if (t==='Yes/No') return 'tag-yesno';
  return 'tag-scale';
}

// ── RENDER BANK ──────────────────────────────────────────────
function renderBank() {
  const container = document.getElementById('question-bank');
  const q = searchQuery.toLowerCase();
  let html = '';
  let visible = 0;

  CATEGORIES.forEach(cat => {
    const qs = cat.questions.filter(x => !q || x.text.toLowerCase().includes(q) || x.type.toLowerCase().includes(q));
    if (!qs.length) return;
    visible += qs.length;
    const isClosed = collapsed.has(cat.name);

    html += `<div>
      <div onclick="toggleCat('${cat.name.replace(/'/g,"&#39;")}')"
           style="display:flex;align-items:center;gap:0;padding:12px 0;cursor:pointer;user-select:none"
           onmouseenter="this.style.background='#fafafa'" onmouseleave="this.style.background='transparent'">
        <span style="width:24px;height:24px;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:transform .2s;transform:rotate(${isClosed?'-90deg':'0'})">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#545470" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </span>
        <span style="font-size:14px;font-weight:500;color:#29294c;flex:1;margin-left:6px">${cat.name}</span>
        <span style="font-size:13px;color:#98a2b3">(${qs.length})</span>
      </div>
      ${isClosed ? '' : `<div style="padding-bottom:4px">${qs.map(q => renderQCard(q, cat.name)).join('')}</div>`}
    </div>`;
  });

  if (!html) html = `<div style="text-align:center;padding:32px 0;color:#98a2b3;font-size:13px">No questions match your search.</div>`;
  container.innerHTML = html;
  document.getElementById('bank-count').textContent = `(${visible})`;
}

function renderQCard(q, catName) {
  const added = selectedIds.has(q.id);
  return `<div style="display:flex;align-items:center;gap:6px;padding:12px;border:1px solid #e1e5ea;border-radius:8px;margin-bottom:8px;background:#fff;transition:border-color .15s"
              onmouseenter="this.style.borderColor='#c9b8f5'" onmouseleave="this.style.borderColor='${added?'#e1e5ea':'#e1e5ea'}'">
    <div style="flex:1;display:flex;flex-direction:column;gap:10px;min-width:0">
      <p style="font-size:14px;font-weight:500;color:#545470;line-height:20px">${q.text}</p>
      <span class="${badgeClass(q.type)}" style="display:inline-flex;align-items:center;align-self:flex-start;padding:2px 8px;border-radius:16px;font-size:12px;font-weight:500;line-height:1.4;letter-spacing:.03px;white-space:nowrap">${q.type}</span>
    </div>
    <button onclick="toggleQ(${q.id})"
            style="width:30px;height:30px;border-radius:8px;background:${added?'#fff':'#7f56d9'};border:${added?'1.5px solid #fda29b':'none'};display:flex;align-items:center;justify-content:center;flex-shrink:0;cursor:pointer;transition:background .15s"
            title="${added?'Remove':'Add question'}"
            onmouseenter="this.style.background='${added?'#fef3f2':'#6941c6'}'"
            onmouseleave="this.style.background='${added?'#fff':'#7f56d9'}'">
      ${added
        ? `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f04438" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>`
        : `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>`
      }
    </button>
  </div>`;
}

// ── RENDER SELECTED ──────────────────────────────────────────
function renderSelected() {
  const body = document.getElementById('sel-body');
  const all = getAllQs().filter(q => selectedIds.has(q.id));

  if (!all.length) {
    body.innerHTML = `<div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px 20px;gap:12px;color:#98a2b3;text-align:center;min-height:300px">
      <svg width="88" height="88" viewBox="0 0 88 88" fill="none" opacity=".5">
        <rect x="10" y="14" width="68" height="60" rx="6" fill="#f2f4f7" stroke="#e4e7ec" stroke-width="1.5"/>
        <rect x="20" y="26" width="30" height="5" rx="2.5" fill="#d0d5dd"/>
        <rect x="20" y="36" width="48" height="3.5" rx="1.75" fill="#e4e7ec"/>
        <rect x="20" y="44" width="40" height="3.5" rx="1.75" fill="#e4e7ec"/>
        <rect x="20" y="52" width="28" height="3.5" rx="1.75" fill="#e4e7ec"/>
        <circle cx="69" cy="64" r="13" fill="#f9fafb" stroke="#e4e7ec" stroke-width="1.5"/>
        <path d="M65 64 Q69 58 73 64" stroke="#d0d5dd" stroke-width="1.5" fill="none" stroke-linecap="round"/>
        <circle cx="67" cy="62.5" r="1.2" fill="#d0d5dd"/>
        <circle cx="71" cy="62.5" r="1.2" fill="#d0d5dd"/>
      </svg>
      <div style="font-size:14px;font-weight:600;color:#667085">No questions selected</div>
      <div style="font-size:13px;color:#98a2b3">Add questions from the library to build your survey</div>
    </div>`;
    return;
  }

  const groups = {};
  all.forEach((q,i) => {
    const k = q.category || 'Custom';
    if (!groups[k]) groups[k] = [];
    groups[k].push({...q, idx: i+1});
  });

  let idx = 1;
  let html = '';
  Object.entries(groups).forEach(([cat, qs]) => {
    qs.forEach(q => {
      html += `<div style="border:1px solid #e1e5ea;border-radius:6px;background:#fff;padding:20px 24px;margin-bottom:8px">
        <div style="display:flex;align-items:center;gap:12px">
          <div style="flex:1;display:flex;flex-direction:column;gap:10px;min-width:0">
            <p style="font-size:14px;font-weight:500;color:#29294c;line-height:20px">
              <span style="color:#707087">Q${idx++}.</span> ${q.text}
            </p>
            <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
              <span style="display:inline-flex;align-items:center;align-self:flex-start;padding:2px 8px;border-radius:16px;font-size:12px;font-weight:500;border:1px solid #d0d5dd;color:#29294c;background:#fff;white-space:nowrap">${cat}</span>
              <span class="${badgeClass(q.type)}" style="display:inline-flex;align-items:center;align-self:flex-start;padding:2px 8px;border-radius:16px;font-size:12px;font-weight:500;line-height:1.4;letter-spacing:.03px;white-space:nowrap">${q.type}</span>
            </div>
          </div>
          <button onclick="toggleQ(${q.id})" style="width:24px;height:24px;display:flex;align-items:center;justify-content:center;color:#98a2b3;border:none;background:transparent;border-radius:6px;cursor:pointer;flex-shrink:0" onmouseenter="this.style.background='#f9fafb'" onmouseleave="this.style.background='transparent'">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
        </div>
      </div>`;
    });
  });
  body.innerHTML = html;
}

// ── RENDER PREVIEW ───────────────────────────────────────────
function renderPreview() {
  const body = document.getElementById('preview-body');
  const all = getAllQs().filter(q => selectedIds.has(q.id));

  if (!all.length) {
    body.innerHTML = `<div style="flex:1;display:flex;align-items:center;justify-content:center;font-size:13px;color:#98a2b3;text-align:center;padding:20px;min-height:200px">Add questions to see the preview</div>`;
    return;
  }

  const total = all.length;
  if (previewIndex >= total) previewIndex = total - 1;
  const current = all[previewIndex];
  const progressPct = Math.round(((previewIndex + 1) / total) * 100);

  let responseHtml = '';
  if (current.type.startsWith('Rating') || current.type.startsWith('Scale')) {
    const max = current.type.includes('10') ? 10 : 5;
    const labels = max<=5 ? ['Strongly disagree','Strongly agree'] : ['Strongly disagree','Strongly agree'];
    const btnCount = max<=5 ? 5 : 10;
    responseHtml = `
      <div style="display:flex;flex-direction:column;gap:10px;width:${btnCount<=5?268:508}px">
        <div class="pp-rating-btns">
          ${Array.from({length:btnCount},(_, i)=>`
            <button onclick="selectRating(${i+1},this)" class="rating-btn" id="rbtn-${i+1}">${i+1}</button>
          `).join('')}
        </div>
        <div style="display:flex;justify-content:space-between;font-size:12px;color:#707087;line-height:1.4;letter-spacing:.03px">
          <span>Strongly disagree</span><span>Strongly agree</span>
        </div>
      </div>`;
  } else if (current.type==='MCQ') {
    responseHtml = ['Always','Often','Sometimes','Rarely','Never'].map(o=>`
      <label style="display:flex;align-items:center;gap:10px;padding:10px 12px;border:1px solid #e1e5ea;border-radius:8px;cursor:pointer;margin-bottom:6px;font-size:13px;color:#344054" onmouseenter="this.style.borderColor='#9e77ed'" onmouseleave="this.style.borderColor='#e1e5ea'">
        <span style="width:16px;height:16px;border:1.5px solid #d0d5dd;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:#fff"></span>${o}
      </label>`).join('');
  } else if (current.type==='Yes/No') {
    responseHtml = ['Yes','No'].map(o=>`
      <label style="display:flex;align-items:center;gap:10px;padding:10px 12px;border:1px solid #e1e5ea;border-radius:8px;cursor:pointer;margin-bottom:6px;font-size:13px;color:#344054" onmouseenter="this.style.borderColor='#9e77ed'" onmouseleave="this.style.borderColor='#e1e5ea'">
        <span style="width:16px;height:16px;border:1.5px solid #d0d5dd;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:#fff"></span>${o}
      </label>`).join('');
  } else {
    responseHtml = `<textarea placeholder="Your answer..." style="width:100%;height:80px;border:1px solid #d0d5dd;border-radius:6px;padding:8px 12px;font-family:'Inter',sans-serif;font-size:13px;color:#101828;resize:none;outline:none"></textarea>`;
  }

  body.innerHTML = `
    <!-- Progress -->
    <div style="display:flex;align-items:center;justify-content:center;gap:12px;margin-bottom:20px;flex-shrink:0">
      <span style="font-size:12px;color:#707087;font-weight:400;line-height:1.4;letter-spacing:.03px;white-space:nowrap">${previewIndex + 1} of ${total}</span>
      <div style="width:130px;height:7px;background:#f5fbff;border-radius:78px;overflow:hidden;position:relative">
        <div style="height:100%;width:${progressPct}%;background:#98a2b3;border-radius:78px"></div>
      </div>
    </div>

    <!-- Question card -->
    <div style="background:#fff;border-radius:10px;box-shadow:0 4px 8px 0 rgba(16,24,40,.1),0 2px 4px 0 rgba(16,24,40,.06);padding:14px;display:flex;flex-direction:column;gap:30px;flex:1;overflow-y:auto;min-height:0">

      <div style="display:flex;flex-direction:column;gap:30px">
        <!-- Question text -->
        <p style="font-size:14px;font-weight:600;color:#29294c;line-height:1.4;letter-spacing:.021px">${current.text}</p>

        <!-- Response -->
        <div>${responseHtml}</div>

        <!-- Comment box (for rating types) -->
        ${(current.type.startsWith('Rating')||current.type.startsWith('Scale'))?`
        <div style="display:flex;flex-direction:column;gap:6px">
          <div style="display:flex;align-items:center;gap:2px">
            <span style="font-size:12px;color:#545470;line-height:1.4;letter-spacing:.03px">Add your comment </span>
          </div>
          <textarea placeholder="" style="width:100%;height:80px;border:1px solid #d0d5dd;border-radius:6px;padding:8px 16px;font-family:'Inter',sans-serif;font-size:14px;color:#101828;resize:none;outline:none"
            onfocus="this.style.borderColor='#7f56d9';this.style.boxShadow='0 0 0 3px rgba(127,86,217,.1)'"
            onblur="this.style.borderColor='#d0d5dd';this.style.boxShadow='none'"></textarea>
          <!-- Skip question -->
          <button style="display:inline-flex;align-items:center;gap:8px;padding:6px 0;font-size:12px;font-weight:500;color:#6941c6;line-height:1.4;letter-spacing:.03px;background:none;border:none;cursor:pointer;font-family:'Inter',sans-serif">
            Skip Question
            <img src="https://www.figma.com/api/mcp/asset/bd85e03a-2437-4734-aa9e-377fa4cb49c8" width="16" height="16" alt=""/>
          </button>
        </div>` : ''}
      </div>

      <!-- Back / Next -->
      <div style="display:flex;align-items:center;justify-content:space-between;flex-shrink:0">
        <button onclick="previewNav(-1)" ${previewIndex===0?'disabled':''} style="display:flex;align-items:center;gap:4px;min-width:60px;width:88px;padding:4px 12px;border-radius:50px;border:1px solid #d0d5dd;background:#fff;font-family:'Poppins',sans-serif;font-size:12px;font-weight:500;color:${previewIndex===0?'#d0d5dd':'#29294c'};justify-content:center;cursor:${previewIndex===0?'not-allowed':'pointer'}" ${previewIndex>0?'onmouseenter="this.style.background=\'#f9fafb\'" onmouseleave="this.style.background=\'#fff\'"':''}>
          <img src="https://www.figma.com/api/mcp/asset/5a977cbc-0631-4920-9001-8e541e49ffca" width="11" height="11" alt="" style="transform:scaleX(-1)"/>
          Back
        </button>
        <button onclick="previewNav(1)" ${previewIndex===total-1?'disabled':''} style="display:flex;align-items:center;gap:4px;min-width:60px;width:88px;padding:4px 12px;border-radius:50px;border:1px solid #d0d5dd;background:#fff;font-family:'Poppins',sans-serif;font-size:12px;font-weight:500;color:${previewIndex===total-1?'#d0d5dd':'#29294c'};justify-content:center;cursor:${previewIndex===total-1?'not-allowed':'pointer'}" ${previewIndex<total-1?'onmouseenter="this.style.background=\'#f9fafb\'" onmouseleave="this.style.background=\'#fff\'"':''}>
          Next
          <img src="https://www.figma.com/api/mcp/asset/67f32449-7a02-4198-8e7d-2660f5a2bf7e" width="11" height="11" alt=""/>
        </button>
      </div>
    </div>`;
}

function previewNav(dir) {
  const all = getAllQs().filter(q => selectedIds.has(q.id));
  previewIndex = Math.max(0, Math.min(all.length - 1, previewIndex + dir));
  renderPreview();
}

function togglePreview() {
  document.querySelector('.panel-prev').classList.toggle('collapsed');
}

function selectRating(val, btn) {
  const parent = btn.closest('.pp-rating-btns');
  if (!parent) return;
  parent.querySelectorAll('.rating-btn').forEach(b => b.classList.remove('selected-r'));
  btn.classList.add('selected-r');
}

// ── STATS ────────────────────────────────────────────────────
function updateStats() {
  const count = selectedIds.size;
  const all   = getAllQs().filter(q => selectedIds.has(q.id));
  const cats  = new Set(all.map(q => q.category||'Custom'));
  document.getElementById('stat-count').textContent = count;
  document.getElementById('stat-cats').textContent  = cats.size;
  document.getElementById('stat-time').textContent  = Math.round(count*20);
  document.getElementById('continue-btn').disabled  = count===0;
}

// ── ACTIONS ──────────────────────────────────────────────────
function addAllQuestions() {
  const all = getAllQs();
  const allAdded = all.length > 0 && all.every(q => selectedIds.has(q.id));
  if (allAdded) {
    all.forEach(q => selectedIds.delete(q.id));
  } else {
    all.forEach(q => selectedIds.add(q.id));
  }
  previewIndex = 0;
  renderAll();
  updateAddAllCheckbox();
}

function clearAllQuestions() {
  selectedIds.clear();
  previewIndex = 0;
  renderAll();
  updateAddAllCheckbox();
}

function updateAddAllCheckbox() {
  const all = getAllQs();
  const allAdded = all.length > 0 && all.every(q => selectedIds.has(q.id));
  const cb  = document.getElementById('add-all-cb');
  const chk = document.getElementById('add-all-check');
  const clearBtn = document.getElementById('clear-all-btn');
  const divider  = document.getElementById('clear-all-divider');
  if (cb) {
    cb.style.background  = allAdded ? '#6941c6' : '#fff';
    cb.style.borderColor = allAdded ? '#6941c6' : '#d0d5dd';
  }
  if (chk) chk.style.display = allAdded ? 'block' : 'none';
  if (clearBtn) clearBtn.style.display = selectedIds.size > 0 ? 'flex' : 'none';
  if (divider)  divider.style.display  = selectedIds.size > 0 ? 'block' : 'none';
}

function toggleQ(id) {
  if (selectedIds.has(id)) {
    selectedIds.delete(id);
    const remaining = getAllQs().filter(q => selectedIds.has(q.id)).length;
    if (previewIndex >= remaining) previewIndex = Math.max(0, remaining - 1);
  } else {
    selectedIds.add(id);
    toast('Question added','success');
  }
  renderAll();
}
function toggleCat(name) {
  if (collapsed.has(name)) collapsed.delete(name); else collapsed.add(name);
  renderBank();
}
function addAllQuestions() {
  const q = searchQuery.toLowerCase();
  const qs = getAllQs().filter(x => !q || x.text.toLowerCase().includes(q));
  qs.forEach(x => selectedIds.add(x.id));
  renderAll();
  toast(`${qs.length} questions added`,'success');
}
function clearAllQuestions() {
  if (!selectedIds.size) return;
  selectedIds.clear();
  renderAll();
  toast('All questions removed');
}
function filterQuestions(v) { searchQuery=v; renderBank(); }

// ── CUSTOM MODAL ─────────────────────────────────────────────
function openCustomModal()  { document.getElementById('custom-modal').classList.add('open'); }
function closeCustomModal() {
  document.getElementById('custom-modal').classList.remove('open');
  document.getElementById('cq-text').value='';
}
function submitCustom() {
  const text = document.getElementById('cq-text').value.trim();
  if (!text) { alert('Please enter a question text.'); return; }
  const type = document.getElementById('cq-type').value;
  const cat  = document.getElementById('cq-cat').value || 'Custom';
  const id   = ++customCounter;
  let c = CATEGORIES.find(x => x.name===cat);
  if (!c) { c={name:cat,questions:[]}; CATEGORIES.push(c); }
  c.questions.push({id, text, type});
  selectedIds.add(id);
  closeCustomModal();
  renderAll();
  toast('Custom question added','success');
}

// ── TOAST ────────────────────────────────────────────────────
function toast(msg, type='') {
  const ct = document.getElementById('toasts');
  const t  = document.createElement('div');
  t.className = 'toast'+(type?' '+type:'');
  t.innerHTML = (type==='success'
    ? `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`
    : `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>`
  )+msg;
  ct.appendChild(t);
  setTimeout(()=>{ t.style.opacity='0'; setTimeout(()=>t.remove(),300); }, 2200);
}

function renderAll() { renderBank(); renderSelected(); renderPreview(); updateStats(); updateAddAllCheckbox(); }

document.addEventListener('keydown', e => { if (e.key==='Escape') closeCustomModal(); });
renderAll();

// ── SIDEBAR COLLAPSE ─────────────────────────────────────────
(function(){
  var sidebar=document.querySelector('.side-nav');
  var page=document.querySelector('.page');
  if(sidebar&&localStorage.getItem('sidebarCollapsed')==='true'){
    sidebar.classList.add('collapsed');
    if(page)page.style.marginLeft='64px';
  }
})();
function toggleSidebar(){
  var sidebar=document.querySelector('.side-nav');
  var page=document.querySelector('.page');
  if(!sidebar)return;
  var c=sidebar.classList.toggle('collapsed');
  localStorage.setItem('sidebarCollapsed',c?'true':'false');
  if(page)page.style.marginLeft=c?'64px':'252px';
}
</script>
</body>
</html>
