{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@pulse-ds/ui": ["ui/src/index.ts"],
      "@pulse-ds/ui/*": ["ui/*/src/index.ts"],
      "@vantagecircle/vantage-ui/*": ["ui/*/src/index.ts"],
      "@vantagecircle/ui/*": ["ui/*/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
