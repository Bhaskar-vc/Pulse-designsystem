{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "pulse-ds": {
      "root": "",
      "sourceRoot": "ui/src",
      "projectType": "application",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/app",
            "tsConfig": "tsconfig.base.json",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": ["zone.js"],
            "styles": [
              "tokens.css",
              "ui/src/styles.scss"
            ]
          }
        },
        "storybook": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": ".storybook",
            "browserTarget": "pulse-ds:build",
            "compodoc": false,
            "port": 4400
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "configDir": ".storybook",
            "browserTarget": "pulse-ds:build",
            "compodoc": false,
            "outputDir": "dist/storybook"
          }
        }
      }
    }
  }
}
